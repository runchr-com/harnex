{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@runchr/shared": [
        "packages/shared/src/index.ts"
      ],
      "@runchr/core": [
        "packages/core/src/index.ts"
      ],
      "@runchr/openwork": [
        "packages/openwork/src/index.ts"
      ],
      "@runchr/paperclip": [
        "packages/paperclip/src/index.ts"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  }
}
